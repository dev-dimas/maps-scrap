{
  "name": "@openrol/maps-scrap",
  "version": "0.1.0",
  "description": "Powerful Maps scraping library and CLI built with Playwright",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "bin": {
    "maps-scrap": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "maps",
    "scraper",
    "playwright",
    "lead-generation",
    "business-data"
  ],
  "repository": "https://github.com/dev-dimas/maps-scrap",
  "license": "MIT",
  "scripts": {
    "build": "bun build src/index.ts --target=node --format=esm --packages=external --outfile dist/index.js && bun build src/cli.ts --target=node --format=esm --packages=external --outfile dist/cli.js",
    "check": "bun run build",
    "dev": "bun --watch src/cli.ts -- --help",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "playwright": "^1.44.0",
    "commander": "^12.1.0",
    "@fast-csv/format": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "playwright"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
